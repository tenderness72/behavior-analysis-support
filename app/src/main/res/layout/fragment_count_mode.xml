<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="32dp">

        <!-- 行動情報カード -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/teal_500"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_behavior_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="5dp" />

                    <TextView
                        android:id="@+id/tv_behavior_definition"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_medium"
                        android:lineSpacingExtra="2dp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- インターバル設定カード -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="インターバル設定"
                    android:textSize="12sp"
                    android:textColor="@color/teal_700"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinner_interval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- カウントモードトグルボタン -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_count_mode"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:text="カウント開始"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/teal_700"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_media_play"
            app:iconGravity="start"
            app:iconTint="@color/white" />

        <!-- タイマー＋インターバル情報エリア（インターバル中のみ表示） -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_timer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/teal_50"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/teal_700"
                    android:text="残り 0.0 秒" />

                <TextView
                    android:id="@+id/tv_interval_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_medium"
                    android:layout_marginTop="4dp"
                    android:text="インターバル: 0" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- カウント表示エリア -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface">

            <TextView
                android:id="@+id/tv_count"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:text="0"
                android:textSize="96sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/teal_700" />

        </androidx.cardview.widget.CardView>

        <!-- +/-ボタン -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_decrement"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="−"
                android:textSize="36sp"
                android:textColor="@color/teal_700"
                android:backgroundTint="@color/surface"
                android:enabled="false"
                app:cornerRadius="12dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_increment"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="＋"
                android:textSize="36sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/teal_700"
                android:enabled="false"
                app:cornerRadius="12dp" />

        </LinearLayout>

        <!-- 保存/リセットボタン -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/button_reset"
                android:textColor="@color/on_surface_medium"
                android:backgroundTint="@color/surface"
                app:cornerRadius="10dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="2"
                android:layout_marginStart="8dp"
                android:text="@string/button_save"
                android:textColor="@color/white"
                android:backgroundTint="@color/teal_700"
                android:enabled="false"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
