<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BehaviorAnalysisApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/teal_700</item>
        <item name="colorPrimaryDark">@color/teal_900</item>
        <item name="colorAccent">@color/teal_400</item>
        <item name="android:windowBackground">@color/background</item>
        <!-- ステータスバーとナビゲーションバーの色 -->
        <item name="android:statusBarColor">@color/teal_900</item>
        <item name="android:navigationBarColor">@color/white</item>
        <!-- システムバー領域をコンテンツで使わない（かぶり防止） -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="28">shortEdges</item>
    </style>

    <!-- カード共通スタイル -->
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="contentPaddingTop">0dp</item>
        <item name="contentPaddingBottom">0dp</item>
        <item name="contentPaddingLeft">0dp</item>
        <item name="contentPaddingRight">0dp</item>
    </style>

    <!-- 主要ボタンスタイル -->
    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/teal_700</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- アウトラインボタンスタイル -->
    <style name="OutlineButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/teal_700</item>
        <item name="android:textColor">@color/teal_700</item>
        <item name="cornerRadius">8dp</item>
    </style>
</resources>
